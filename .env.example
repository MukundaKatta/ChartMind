# ChartMind Configuration
# Copy this file to .env and fill in the values

# Default chart width (pixels)
CHARTMIND_DEFAULT_WIDTH=800

# Default chart height (pixels)
CHARTMIND_DEFAULT_HEIGHT=400

# Default color palette: "vibrant" | "pastel" | "monochrome" | "earth"
CHARTMIND_PALETTE=vibrant

# Enable debug logging
CHARTMIND_DEBUG=false
